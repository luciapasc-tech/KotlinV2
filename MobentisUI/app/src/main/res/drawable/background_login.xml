<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2E3135" />
        </shape>
    </item>

    <item>
        <gradient
            android:angle="315"
            android:endColor="#1A1C1E"
            android:startColor="#3E4246"
            android:type="linear" />
    </item>

    <item android:top="-100dp" android:left="-50dp">
        <rotate
            android:fromDegrees="45"
            android:pivotX="0%"
            android:pivotY="0%">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFF" />
                <size android:width="300dp" android:height="600dp" />
                <gradient
                    android:startColor="#0FFFFFFF"
                    android:endColor="#00FFFFFF"
                    android:angle="90"/>
            </shape>
        </rotate>
    </item>
</layer-list>